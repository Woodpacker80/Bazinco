<!-- Firebase SDK -->
<script type="module">
import { initializeApp }         from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, push, query, orderByChild, limitToLast, get }
                                  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

const firebaseConfig = {
  apiKey:            "AIzaSyDWH816XM4PokJKDZHSLjYwqxqPDPMCfgg",
  authDomain:        "bazinco-280f9.firebaseapp.com",
  databaseURL:       "https://bazinco-280f9-default-rtdb.europe-west1.firebasedatabase.app",
  projectId:         "bazinco-280f9",
  storageBucket:     "bazinco-280f9.firebasestorage.app",
  messagingSenderId: "374130581654",
  appId:             "1:374130581654:web:3a528a38bea7af60a722b7",
  measurementId:     "G-D3QFPBXSJ6"
};

const app = initializeApp(firebaseConfig);
const db  = getDatabase(app);

const SCORES_PATH = "bazinco/scores";
const TOP_N       = 20; // fetch top 20, display top 10

// ── Cloud leaderboard API ──────────────────────────────────────────────────

async function cloudAddScore(name, score) {
  const date = new Date().toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
  try {
    await push(ref(db, SCORES_PATH), { name, score, date, ts: Date.now() });
  } catch(e) {
    console.warn("Firebase write failed:", e);
  }
}

async function cloudGetScores() {
  try {
    const q   = query(ref(db, SCORES_PATH), orderByChild("score"), limitToLast(TOP_N));
    const snap = await get(q);
    if (!snap.exists()) return [];
    const arr = [];
    snap.forEach(child => arr.push(child.val()));
    arr.sort((a, b) => b.score - a.score);
    return arr.slice(0, 10);
  } catch(e) {
    console.warn("Firebase read failed:", e);
    return null; // null = fallback to local
  }
}

// Expose to main (non-module) script via window
window.CloudScores = { cloudAddScore, cloudGetScores };
</script>
